<odoo>

    <record id="view_users_form_ai_oauth" model="ir.ui.view">
        <field name="name">res.users.form.ai.oauth</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Grokoo AI Assistant" name="grokoo"
                      groups="grokoo.group_ai_user">
                    <group>
                        <field name="grokoo_oauth_set" readonly="1"/>
                        <button name="action_grokoo_logout" type="object"
                                string="Disconnect Grok"
                                class="btn-secondary"
                                invisible="not grokoo_oauth_set"
                                confirm="Disconnect Grok for this user? They will need to reconnect."/>
                    </group>
                    <div class="text-muted">
                        Each user connects Grok from the <b>Grokoo</b> chat using
                        the <b>Connect Grok</b> panel — importing their own Grok
                        login (auth.json) or an xAI API key. Credentials
                        are stored privately per user and are never shared.
                    </div>
                    <group string="Tool Permissions"
                           groups="grokoo.group_ai_manager">
                        <field name="grokoo_tool_ids"
                               widget="many2many_tags"
                               placeholder="Empty = all read-only tools"/>
                        <field name="grokoo_zero_trust_mode"/>
                    </group>
                </page>
            </xpath>
        </field>
    </record>

    <!-- Same status on the simplified "My Preferences" form -->
    <record id="view_users_form_simple_ai_oauth" model="ir.ui.view">
        <field name="name">res.users.preferences.form.ai.oauth</field>
        <field name="model">res.users</field>
        <field name="inherit_id" ref="base.view_users_form_simple_modif"/>
        <field name="arch" type="xml">
            <xpath expr="//group" position="after">
                <group string="Grokoo AI Assistant" groups="grokoo.group_ai_user">
                    <field name="grokoo_oauth_set" readonly="1"/>
                    <button name="action_grokoo_logout" type="object"
                            string="Disconnect Grok"
                            class="btn-secondary"
                            invisible="not grokoo_oauth_set"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
