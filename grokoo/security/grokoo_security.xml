<odoo noupdate="0">

    <record id="module_category_grokoo" model="ir.module.category">
        <field name="name">AI Assistant</field>
        <field name="sequence">90</field>
    </record>

    <record id="group_ai_user" model="res.groups">
        <field name="name">AI Assistant User</field>
        <field name="category_id" ref="module_category_grokoo"/>
        <field name="comment">Can use the AI Assistant chat.</field>
    </record>

    <record id="group_ai_sql_analyst" model="res.groups">
        <field name="name">AI SQL Analyst</field>
        <field name="category_id" ref="module_category_grokoo"/>
        <field name="implied_ids" eval="[(4, ref('group_ai_user'))]"/>
        <field name="comment">May run read-only SQL reports through the AI Assistant.</field>
    </record>

    <record id="group_ai_manager" model="res.groups">
        <field name="name">AI Assistant Manager</field>
        <field name="category_id" ref="module_category_grokoo"/>
        <field name="implied_ids" eval="[(4, ref('group_ai_sql_analyst'))]"/>
        <field name="comment">Can configure the assistant and view all audit logs.</field>
    </record>

    <!-- Grant system admins the AI groups by default. -->
    <record id="base.group_system" model="res.groups">
        <field name="implied_ids" eval="[(4, ref('group_ai_manager'))]"/>
    </record>

    <!-- A user only sees their own conversations. -->
    <record id="rule_session_own" model="ir.rule">
        <field name="name">AI sessions: own only</field>
        <field name="model_id" ref="model_grokoo_session"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('group_ai_user'))]"/>
    </record>

    <!-- Managers see all sessions. -->
    <record id="rule_session_manager" model="ir.rule">
        <field name="name">AI sessions: manager all</field>
        <field name="model_id" ref="model_grokoo_session"/>
        <field name="domain_force">[(1, '=', 1)]</field>
        <field name="groups" eval="[(4, ref('group_ai_manager'))]"/>
    </record>

</odoo>
